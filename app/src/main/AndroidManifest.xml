<?xml version="1.0" encoding="utf-8" ?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!--
        No READ/WRITE_EXTERNAL_STORAGE permissions are requested.
        Access to the user-selected folder is granted via the
        Storage Access Framework (ACTION_OPEN_DOCUMENT_TREE) and
        persisted with takePersistableUriPermission, which does not
        require any manifest-declared storage permission.
    -->

    <application
    android:allowBackup="true"
    android:icon="@mipmap/ic_launcher"
    android:label="@string/app_name"
    android:supportsRtl="true"
    android:theme="@style/Theme.Ren"
  >

        <activity
      android:name=".MainActivity"
      android:exported="true"
      android:theme="@style/Theme.Ren"
    >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
